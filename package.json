{
  "private": true,
  "name": "boilerplate_parcel",
  "version": "3.0.0",
  "description": "web development env boilerplate with parcel",
  "license": "MIT",
  "scripts": {
    "build": "parcel build src/html/index.pug --no-optimize --no-source-maps --public-url ./",
    "lint:html": "markuplint 'dist/**/*.html'",
    "lint:css": "stylelint 'dist/**/*.css'",
    "start": "parcel src/html/index.pug --open --no-cache",
    "test": "npm run lint:css && npm run lint:html",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@parcel/transformer-pug": "^2.16.4",
    "@parcel/transformer-sass": "^2.16.4",
    "@prettier/plugin-pug": "^3.4.2",
    "autoprefixer": "^10.4.27",
    "husky": "^9.1.7",
    "markuplint": "^4.14.1",
    "parcel": "^2.16.4",
    "pug": "^3.0.3",
    "sass": "^1.97.3",
    "stylelint": "^17.4.0",
    "stylelint-config-recommended": "^18.0.0",
    "typescript": "^5.9.3"
  }
}
